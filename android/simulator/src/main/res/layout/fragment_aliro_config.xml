<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aliro Reader Configuration"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter values as hex strings. Private key and Reader ID are required. Issuer Public Key and Certificate are only needed when using Reader Certificates."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <!-- Import from Credential App -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import from Credential App"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan the QR code from the credential app\u2019s \u201cExport Reader Config\u201d to auto-fill all fields below. Tap Save after scanning."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnImportFromCredential"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import from Credential"
            android:backgroundTint="#1E7A4D"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp" />

        <!-- Reader Private Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reader Private Key (32 bytes / 64 hex chars)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editReaderPrivateKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 4a3b2c1d..."
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:maxLines="2"
            android:layout_marginBottom="20dp" />

        <!-- Reader ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reader Identifier (32 bytes / 64 hex chars)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editReaderId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 7f8e9d0c..."
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:maxLines="2"
            android:layout_marginBottom="8dp" />

        <!-- Certificate divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reader Certificate (optional)"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="12dp" />

        <!-- Reader Issuer Public Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reader Issuer Public Key (65 bytes / 130 hex chars)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editReaderIssuerPublicKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="04... (leave blank if not using a certificate)"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:maxLines="3"
            android:layout_marginBottom="20dp" />

        <!-- Reader Certificate -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reader Certificate (hex bytes)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editReaderCertificate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="(leave blank if not using a certificate)"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:maxLines="4"
            android:layout_marginBottom="12dp" />

        <!-- Cert Delivery Mode -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cert Delivery Mode"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerCertMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/chkForceChaining"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Force command chaining (for WITH_CHAINING tests)"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/chkFastMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FAST mode (use Kpersistent from prior STANDARD)"
            android:layout_marginBottom="32dp" />

        <!-- Step-Up divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step-Up Configuration (optional)"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure the Step-Up flow to request Access Document data elements from the credential after authentication."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Step-Up Element Identifier -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step-Up Element Identifier"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editStepUpElementId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. access"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:maxLines="1"
            android:layout_marginBottom="20dp" />

        <!-- Step-Up Issuer Public Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step-Up Issuer Public Key (65 bytes / 130 hex chars)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editStepUpIssuerPubKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="04... (leave blank to skip COSE_Sign1 verification)"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:maxLines="3"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnScanIssuerKeyQr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan QR Code"
            android:backgroundTint="@color/colorPrimaryDark"
            android:textColor="@android:color/white"
            android:layout_marginBottom="32dp" />


        <!-- Mailbox divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mailbox Configuration"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure mailbox operations sent in the EXCHANGE command. The credential maintains a persistent byte array that the reader can read, write, or fill."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/chkMailboxEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable mailbox operations"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Operation type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Operation"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerMailboxOperation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Offset -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Offset (bytes, 0-based)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editMailboxOffset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="0 (bytes)"
            android:inputType="number"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- Length (for read/set) -->
        <TextView
            android:id="@+id/lblMailboxLength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Read Length (bytes)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerMailboxLength"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Data (for write) -->
        <TextView
            android:id="@+id/lblMailboxData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Data (hex string)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/editMailboxData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. DEADBEEF"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Set value (for set/fill) -->
        <TextView
            android:id="@+id/lblMailboxSetValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fill Value (2 hex chars, e.g. FF)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/editMailboxSetValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="00"
            android:inputType="textNoSuggestions"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:maxLength="2"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Atomic session -->
        <CheckBox
            android:id="@+id/chkMailboxAtomic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use atomic session"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Save button -->
        <Button
            android:id="@+id/btnSaveAliroConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp" />

        <!-- Status message -->
        <TextView
            android:id="@+id/txtAliroConfigStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
