<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeFragment">

    <!-- Reader background fills entire screen -->
    <ImageView
        android:id="@+id/readerImageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/reader_background"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- Scroll content floats over the top portion of the image -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintVertical_bias="0">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00FFFFFF"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:background="@android:color/transparent"
                android:text="Scan a PKOC NFC or BLE Credential"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/colorPrimaryDark"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/readerLocationUUID"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textView"
                android:layout_marginTop="16dp"
                android:text="Reader Location UUID: "
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/readerSiteUUID"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/readerLocationUUID"
                android:layout_marginTop="8dp"
                android:text="Reader Site UUID: "
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/sitePublicKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/readerSiteUUID"
                android:layout_marginTop="8dp"
                android:text="Site Public Key: "
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/nfcadvertisingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/sitePublicKey"
                android:layout_marginTop="8dp"
                android:text="NFC Advertising Status: "
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/bleadvertisingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/nfcadvertisingStatus"
                android:layout_marginTop="8dp"
                android:text="BLE Advertising Status: "
                android:textSize="16sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/emailButton"
                style="@android:style/Widget.Material.Button.Inset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/bleadvertisingStatus"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="Email PKOC Information"
                android:visibility="gone" />

            <Button
                android:id="@+id/scanButton"
                style="@android:style/Widget.Material.Button.Inset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/emailButton"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="Scan New Tag"
                android:visibility="gone" />

            <!-- Protocol mode toggle -->
            <RadioGroup
                android:id="@+id/protocolModeGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/bleadvertisingStatus"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/modePkoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="PKOC"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="14sp"
                    android:buttonTint="@color/colorPrimary" />

                <RadioButton
                    android:id="@+id/modeAliro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="Aliro"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="14sp"
                    android:buttonTint="@color/colorPrimary" />

                <RadioButton
                    android:id="@+id/modeLeaf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="LEAF Verified"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="14sp"
                    android:buttonTint="@color/colorPrimary" />

                <RadioButton
                    android:id="@+id/modeAuto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Auto"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="14sp"
                    android:buttonTint="@color/colorPrimary" />

            </RadioGroup>

            <Button
                android:id="@+id/rdrButton"
                style="@android:style/Widget.Material.Button.Inset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/protocolModeGroup"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="Show Reader Details"
                android:visibility="visible" />

            <Button
                android:id="@+id/btnAliroBle"
                style="@android:style/Widget.Material.Button.Inset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/rdrButton"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="Start Aliro BLE"
                android:visibility="gone" />

        </RelativeLayout>
    </ScrollView>

    <!-- Guidelines as % of the full screen -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineKeypadTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineKeypadBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.96" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.08" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.92" />

    <!-- Keypad: hidden/shown together with readerImageView via Java -->
    <LinearLayout
        android:id="@+id/keypadLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:weightSum="5"
        android:background="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/guidelineLeft"
        app:layout_constraintRight_toLeftOf="@id/guidelineRight">

        <!-- PIN display -->
        <TextView
            android:id="@+id/pinDisplay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:hint=""
            android:textColor="#AAAAAA"
            android:textColorHint="#CCCCCC"
            android:fontFamily="sans-serif-light"
            android:textSize="18sp"
            android:letterSpacing="0.3"
            android:background="@null"
            android:backgroundTint="@null" />

        <!-- Row 1: 1 2 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@null">
            <Button android:id="@+id/key1" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="1"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/key2" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="2"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/key3" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="3"
                android:background="@null" android:backgroundTint="@null" />
        </LinearLayout>

        <!-- Row 2: 4 5 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@null">
            <Button android:id="@+id/key4" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="4"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/key5" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="5"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/key6" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="6"
                android:background="@null" android:backgroundTint="@null" />
        </LinearLayout>

        <!-- Row 3: 7 8 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@null">
            <Button android:id="@+id/key7" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="7"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/key8" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="8"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/key9" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="9"
                android:background="@null" android:backgroundTint="@null" />
        </LinearLayout>

        <!-- Row 4: * 0 # -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@null">
            <Button android:id="@+id/keyStar" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="*"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/key0" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="0"
                android:background="@null" android:backgroundTint="@null" />
            <Button android:id="@+id/keyHash" style="@style/KeypadButton"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:text="#"
                android:background="@null" android:backgroundTint="@null" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
