<?xml version="1.0" encoding="utf-8"?>
<!--
    Wear OS HCE Spike — main layout.

    Plain LinearLayout with a TextView. The default Wear theme handles
    round/square chinning and chin insets automatically. This isn't trying
    to be a polished Wear UI — it just needs to render legible text on the
    watch face so a tester can confirm the spike worked without adb.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:text="@string/status_waiting" />

</LinearLayout>
