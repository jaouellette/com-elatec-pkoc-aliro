<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Wear OS HCE feasibility spike.

        Goal: prove (or disprove) that a third-party HCE service running on
        Wear OS receives APDUs when the watch is held to an NFC reader.

        If this proves the routing works, the same pattern can be extended
        to host the real PKOC, Aliro, and LEAF Verified HCE services on a
        watch app.
    -->

    <uses-permission android:name="android.permission.NFC" />

    <!-- HCE feature is required for this app to be useful at all, but mark
         it not-required so the APK can install on watches without NFC for
         partial testing. The HCE service simply won't activate without NFC. -->
    <uses-feature
        android:name="android.hardware.nfc.hce"
        android:required="false" />

    <uses-feature
        android:name="android.hardware.nfc"
        android:required="false" />

    <!-- Wear OS feature flag — declares this APK as a watch app, so the
         Play Store / sideload tooling treats it correctly. -->
    <uses-feature android:name="android.hardware.type.watch" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- Required for Wear OS to recognize this as a standalone watch app
             that doesn't need a phone-side companion. Set to false if you
             want to also build a phone companion later for credential sync. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <!-- Main activity — provides a UI button to confirm the app is
             installed and shows the last received APDU as visual feedback
             when adb logcat isn't attached. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The HCE service under test.

             Key declarations:
               - exported="true" so the NFC framework can bind to it
               - permission="android.permission.BIND_NFC_SERVICE" is REQUIRED
                 by the framework. Without it, the framework refuses to bind
                 and routing silently fails.
               - intent-filter with action HOST_APDU_SERVICE registers this
                 as an HCE service candidate.
               - meta-data points to apduservice.xml which declares the AID
                 group. -->
        <service
            android:name=".TestHceService"
            android:exported="true"
            android:permission="android.permission.BIND_NFC_SERVICE">
            <intent-filter>
                <action android:name="android.nfc.cardemulation.action.HOST_APDU_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.cardemulation.host_apdu_service"
                android:resource="@xml/apduservice" />
        </service>

    </application>

</manifest>
