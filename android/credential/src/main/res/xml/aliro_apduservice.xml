<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/aliro_servicedesc"
    android:requireDeviceUnlock="false">
    <aid-group android:description="@string/aliro_aiddescription"
        android:category="other">
        <aid-filter android:name="A000000909ACCE5501"/>
        <aid-filter android:name="A000000909ACCE5502"/>
        <!-- Enrollment AID: out-of-band reader provisioning channel.
             Reader emits its pub key + reader ID after a normal SELECT to
             this AID, allowing the credential to provision the reader
             without manual JSON paste. The credential only honors enrollment
             commands when the user has enabled enrollment mode in Settings. -->
        <aid-filter android:name="A000000909ACCE55FE"/>
    </aid-group>
</host-apdu-service>
