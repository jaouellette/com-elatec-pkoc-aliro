<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ================================================================= -->
        <!-- Header -->
        <!-- ================================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LEAF Verified Credential"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#A41D23"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Provision this device as a LEAF Verified credential (Open ID \u2014 Path 1). Generates a Root CA keypair and a self-signed X.509 certificate containing a unique 12-digit Open ID. Export the Root CA to any LEAF reader via QR code."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- ================================================================= -->
        <!-- Status display -->
        <!-- ================================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Provisioning Status"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#A41D23"
            android:layout_marginBottom="8dp" />

        <!-- LEAF status box (Open ID / cert size / Root CA preview) -->
        <TextView
            android:id="@+id/txtLeafStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not provisioned"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="@android:color/darker_gray"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- ================================================================= -->
        <!-- Provision -->
        <!-- ================================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Provision LEAF Credential"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#A41D23"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generates a new LEAF Root CA keypair and a credential certificate with a random 12-digit Open ID. Any previously provisioned LEAF data will be replaced."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLeafProvision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Provision LEAF Credential"
            android:backgroundTint="#A41D23"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- ================================================================= -->
        <!-- Export Root CA + Clear -->
        <!-- ================================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Export &amp; Manage"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#A41D23"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Export the Root CA public key as a QR code for the reader app to scan. The reader uses this key to verify your LEAF credential certificate."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <!-- Export Root CA + Clear row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnLeafExportRootCA"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Export Root CA"
                android:backgroundTint="#1E7A4D"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:enabled="false"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnLeafClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear LEAF"
                android:backgroundTint="@android:color/holo_red_dark"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:enabled="false"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- ================================================================= -->
        <!-- Status message -->
        <!-- ================================================================= -->

        <TextView
            android:id="@+id/txtCredLeafStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
