<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SettingsFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="@dimen/activity_horizontal_margin"
            android:paddingTop="@dimen/activity_vertical_margin"
            android:paddingRight="@dimen/activity_horizontal_margin"
            android:paddingBottom="@dimen/activity_vertical_margin">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_a_transmission_mechanism" />

            <RadioGroup
                android:id="@+id/TransmissionRadioGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/NfcButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/near_field_communication" />

                <RadioButton
                    android:id="@+id/BleButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:enabled="true"
                    android:text="@string/bluetooth_low_energy" />
            </RadioGroup>

            <LinearLayout
                android:id="@+id/BleSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pkoc_flow_mode" />

                <RadioGroup
                    android:id="@+id/RadioGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/UncompressedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/uncompressed" />

                    <RadioButton
                        android:id="@+id/ECHDE_Complete"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:enabled="true"
                        android:text="@string/echde_perfect_secrecy" />
                </RadioGroup>

                <TextView
                    android:id="@+id/ecdheConfigStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:textStyle="italic"
                    android:textSize="12sp"
                    android:textColor="#4472C4"
                    android:text="Using built-in ELATEC defaults" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btnResetEcdheDefaults"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="Reset to Defaults"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        style="?attr/materialButtonOutlinedStyle" />

                    <Button
                        android:id="@+id/btnClearEcdheConfig"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Clear for Custom"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        style="?attr/materialButtonOutlinedStyle" />
                </LinearLayout>

                <TextView
                    android:id="@+id/site_identifier_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/site_identifier_16_bytes_uuid"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/site_identifier_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/enter_site_identifier_uuid"
                    android:inputType="text"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/reader_identifier_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/reader_identifier_16_bytes_uuid"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/reader_identifier_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/enter_reader_identifier_uuid"
                    android:inputType="text"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/site_public_key_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/site_full_full_public_key_65_bytes"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/site_public_key_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/enter_site_full_public_key_in_uncompressed_format"
                    android:inputType="textMultiLine"
                    android:textSize="11sp"
                    android:singleLine="false"
                    android:maxLines="3"
                    android:scrollHorizontally="false" />
                <Button
                    android:id="@+id/scan_site_key_qr_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Scan Reader QR (get Site Public Key)"
                    android:textAllCaps="false"
                    style="?attr/materialButtonOutlinedStyle"/>
                <!-- ============================================================= -->
                <!-- PKOC BLE Per-Reader Certificates (PKOC BLE Transport 2.0.1 §7) -->
                <!-- ============================================================= -->
                <View
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:layout_height="wrap_content"
                    android:background="@android:color/darker_gray"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PKOC BLE Per-Reader Certificates (v2.0.1)"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/pkoc_perreader_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable per-reader certificates (ECDHE PFS)"
                    android:gravity="start"/>

                <RadioGroup
                    android:id="@+id/pkoc_cert_mode_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <RadioButton
                        android:id="@+id/pkoc_cert_mode_demo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Demo (self-signed)"/>

                    <RadioButton
                        android:id="@+id/pkoc_cert_mode_import"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Import"/>
                </RadioGroup>

                <Button
                    android:id="@+id/pkoc_scan_reader_qr_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Scan Reader QR to Trust This Reader"
                    android:textAllCaps="false"
                    style="?attr/materialButtonOutlinedStyle"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:text="Import is only for making THIS device act as a reader. To trust a reader on the credential side, use Scan above."/>

                <LinearLayout
                    android:id="@+id/pkoc_import_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/pkoc_import_cert_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Reader Certificate (138-byte hex)"
                        android:inputType="textMultiLine"
                        android:textSize="11sp"
                        android:singleLine="false"
                        android:maxLines="3"
                        android:scrollHorizontally="false"/>

                    <EditText
                        android:id="@+id/pkoc_import_issuer_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Site Issuer public key (65-byte hex)"
                        android:inputType="textMultiLine"
                        android:textSize="11sp"
                        android:singleLine="false"
                        android:maxLines="3"
                        android:scrollHorizontally="false"/>

                    <EditText
                        android:id="@+id/pkoc_import_priv_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Reader signing private key (PKCS#8 or 32-byte hex)"
                        android:inputType="textMultiLine"
                        android:textSize="11sp"
                        android:singleLine="false"
                        android:maxLines="3"
                        android:scrollHorizontally="false"/>

                    <Button
                        android:id="@+id/pkoc_import_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Import Reader Certificate"
                        android:textAllCaps="false"
                        style="?attr/materialButtonOutlinedStyle"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/pkoc_perreader_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:text=""/>
                <!-- ===================== end per-reader section ===================== -->


                <View
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:layout_height="wrap_content"
                    android:background="@android:color/darker_gray"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/discovery_and_connection_settings"
                    android:layout_marginBottom="4dp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/auto_discover_switch"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_discover_devices"
                    android:gravity="start"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/enable_ranging_switch"
                    android:layout_marginTop="8dp"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/enable_ranging"
                    android:gravity="start"/>

                <TextView
                    android:id="@+id/ranging_slider_label"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="@string/unlock_range"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/ranging_slider_label_near"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/near"/>

                    <androidx.appcompat.widget.AppCompatSeekBar
                        android:layout_marginTop="8dp"
                        android:id="@+id/ranging_slider"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        style="@style/Widget.AppCompat.SeekBar.Discrete"
                        android:max="10"
                        android:progress="0"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:paddingLeft="30dp"
                        android:paddingRight="30dp"
                        android:minHeight="6dip"
                        android:maxHeight="6dip" />

                    <TextView
                        android:id="@+id/ranging_slider_label_far"
                        android:layout_width="wrap_content"
                        android:layout_gravity="center"
                        android:layout_height="wrap_content"
                        android:text="@string/far"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/display_settings" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/display_mac_switch"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/display_device_mac_address"
                    android:gravity="start"/>
            </LinearLayout>

            <!-- ===================== NFC settings (shown when NFC transmission is selected) ===================== -->
            <LinearLayout
                android:id="@+id/NfcSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- ===================== PKOC NFC SE V2 section ===================== -->

                <View
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:layout_height="wrap_content"
                    android:background="@android:color/darker_gray"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PKOC NFC Credential (SE V2, v2.0.1)"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/pkoc_nfc_card_switch"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable PKOC NFC SE V2 card credential"
                    android:gravity="start"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:text="In demo mode a self-signed PKOC-CVC is generated. Export the supplier (this credential's IIR + issuer public key) as a QR to trust it on a reader running Validated Mode."/>

                <Button
                    android:id="@+id/pkoc_export_supplier_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Export Supplier (QR)"
                    android:textAllCaps="false"
                    style="?attr/materialButtonOutlinedStyle"/>

                <TextView
                    android:id="@+id/pkoc_nfc_card_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:text=""/>

                <!-- ===================== end PKOC NFC SE V2 section ===================== -->

            </LinearLayout>
            <!-- ===================== end NFC settings ===================== -->

            <!-- Enrollment section — applies regardless of transmission mode.
                 Configures the over-NFC reader enrollment behavior (Flow #1
                 self-signed via INS 0xE0, and Flow #2 cert-based via INS
                 0xE2/0xE3). See Gate 1 wire spec for protocol details. -->
            <View
                android:layout_width="match_parent"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:layout_height="1dp"
                android:background="@android:color/darker_gray"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enrollment_section_title"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/enrollment_pending_timeout_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enrollment_pending_timeout_label"
                android:textSize="11sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/enrollment_pending_timeout_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="60"
                android:inputType="number"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/enrollment_grace_window_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enrollment_grace_window_label"
                android:textSize="11sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/enrollment_grace_window_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="30"
                android:inputType="number"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/enrollment_cert_validity_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enrollment_cert_validity_label"
                android:textSize="11sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/enrollment_cert_validity_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="number"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/enrollment_cert_validity_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enrollment_cert_validity_hint"
                android:textSize="10sp"
                android:textStyle="italic"
                android:textColor="#888888"
                android:layout_marginBottom="8dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
