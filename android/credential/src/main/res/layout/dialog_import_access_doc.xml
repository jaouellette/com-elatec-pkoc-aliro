<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Access Document (Base64 CBOR)"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editImportCbor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Base64-encoded CBOR DeviceResponse..."
        android:inputType="textMultiLine|textNoSuggestions"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:minLines="4"
        android:maxLines="8"
        android:scrollbars="vertical"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Issuer Public Key (130 hex chars, optional)"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Required for the reader to verify the document signature. Leave blank if the reader already knows the issuer key."
        android:textSize="12sp"
        android:textColor="@color/colorTextSecondary"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editImportIssuerKey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="04... (65 bytes uncompressed, optional)"
        android:inputType="textNoSuggestions"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:maxLines="3" />

</LinearLayout>
