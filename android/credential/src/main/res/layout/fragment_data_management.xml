<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dataManagementRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/labelSites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sites"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/siteRecycler"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:overScrollMode="ifContentScrolls"/>

        <TextView
            android:id="@+id/emptySites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No sites yet."
            android:visibility="gone"
            android:paddingTop="4dp"
            android:textStyle="italic"/>

        <Button
            android:id="@+id/btnAddSite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Site"
            android:layout_marginTop="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33000000"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:id="@+id/labelReaders"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Readers"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/readerRecycler"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:overScrollMode="ifContentScrolls"/>

        <TextView
            android:id="@+id/emptyReaders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No readers yet."
            android:visibility="gone"
            android:paddingTop="4dp"
            android:textStyle="italic"/>

        <Button
            android:id="@+id/btnAddReader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Reader"
            android:layout_marginTop="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33000000"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:id="@+id/labelCaKeystore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CA Keystore (Cert-Based Enrollment)"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/labelCaKeystoreBlurb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Export the CA keystore as JSON for backup or for distribution to other installer devices. Importing is not yet supported in this build."
            android:textSize="11sp"
            android:textColor="@android:color/darker_gray"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/txtCaKeystoreCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 entries"
            android:textSize="11sp"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCopyCaKeystoreJson"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Copy JSON"
                android:textSize="12sp"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/btnShareCaKeystoreJson"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Share JSON"
                android:textSize="12sp"
                android:textAllCaps="false"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>