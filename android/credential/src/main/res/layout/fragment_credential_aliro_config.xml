<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ================================================================= -->
        <!-- Real Credential Provisioning Section -->
        <!-- ================================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Real Credential Provisioning"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Provision this device as a real Aliro credential. Generates an Issuer CA keypair and a reader certificate for use with physical Aliro readers. Export the reader config to any reader device via QR code."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <!-- Provisioning status -->
        <TextView
            android:id="@+id/txtProvisioningStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not provisioned"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="@android:color/darker_gray"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Provision button -->
        <Button
            android:id="@+id/btnProvisionCredential"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Provision Credential"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp" />

        <!-- Strict mode checkbox -->
        <CheckBox
            android:id="@+id/chkStrictMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Strict Mode (reject unauthorized readers)"
            android:textSize="14sp"
            android:enabled="false"
            android:layout_marginBottom="8dp" />

        <!-- Export / Clear row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnExportReaderConfig"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Export Reader Config"
                android:backgroundTint="#1E7A4D"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:enabled="false"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnClearProvisioning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear Provisioning"
                android:backgroundTint="@android:color/holo_red_dark"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:enabled="false"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- ================================================================= -->
        <!-- Test Harness Configuration Section -->
        <!-- ================================================================= -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#4472C4"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Harness Configuration"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#4472C4"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Override the Reader Group ID and Issuer CA for CSA Aliro Test Harness testing without re-provisioning the credential."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reader Group ID (32 hex / 16 bytes):"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/editTestHarnessGroupId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 00113344667799aa00113344667799aa"
            android:inputType="text"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issuer CA Public Key (130 hex / 65 bytes):"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/editTestHarnessIssuerCa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="04abcdef... (uncompressed EC P-256)"
            android:inputType="textMultiLine"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:singleLine="false"
            android:maxLines="3"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reader Public Key (130 hex / 65 bytes, for AUTH1 sig verify):"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/editTestHarnessReaderPubKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="04abcdef... (th_reader_public_key)"
            android:inputType="textMultiLine"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:singleLine="false"
            android:maxLines="3"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnApplyTestHarness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply Test Harness Config"
            android:backgroundTint="#4472C4"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Divider before Access Document section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- ================================================================= -->
        <!-- Access Document Section -->
        <!-- ================================================================= -->

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aliro Access Document"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="An Access Document enables the Aliro Step-Up phase, allowing the reader to request credential-level access rules and validity information."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="20dp" />

        <!-- Current document status -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Document"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtAccessDocStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Access Document stored."
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="@android:color/darker_gray"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <!-- Issuer key row: Copy button + truncated key display -->
        <LinearLayout
            android:id="@+id/layoutIssuerKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnCopyIssuerKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy Key"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <Button
                android:id="@+id/btnShowQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show QR"
                android:backgroundTint="@color/colorPrimaryDark"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <TextView
                android:id="@+id/txtIssuerKeyPreview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

        <Button
            android:id="@+id/btnClearDoc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear Document"
            android:enabled="false"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Stored Documents (multi-doc per Aliro 1.0 §8.4.2) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stored Documents"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A credential may carry multiple Access Documents (Aliro 1.0 §8.4.2), each with its own issuer keypair and its own kid. Use this list to switch between stored documents — &quot;Add Element&quot; and &quot;Generate / Load&quot; below operate on the currently-selected document. To create a brand-new document with its own fresh issuer key, tap Create New Document."
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerStoredDocs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnCreateNewDoc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create New Document"
                android:backgroundTint="#1E7A4D"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnDeleteCurrentDoc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete Current"
                android:backgroundTint="@android:color/holo_red_dark"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Refresh Validity: bumps the document-level validUntil AND every
             schedule's endPeriod to a far-future date. Preserves issuer
             keypair / kid (Aliro 1.0 §7.3 / §8.4.2) so the reader's CSV does
             not need to change. Useful when a document was created with the
             legacy 2026-04-30 endPeriod (kept for byte-identity with stored
             ELATEC001 fixtures) and is now past that cliff. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bump this document's validity windows (document validUntil + every schedule's endPeriod) without changing rules, schedules, or issuer key. Useful if the doc was generated with the legacy end date and is now past §7.3.4 [start, endPeriod) expiration."
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnRefreshValidity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Validity"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Generate test document -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate / Load Document"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&quot;Generate Test Doc&quot; and &quot;Load Sample Doc&quot; each create a brand-new Access Document with its own fresh issuer keypair (new kid) — existing stored documents are preserved. Use &quot;Add Element to Document&quot; below to append more elements to the currently-selected document; the issuer keypair is reused so the kid stays stable, and the new element honors the Employee/Badge ID and Schedule Preset configured below. All modes use on-device issuer keypairs — not for production use."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Element Identifier"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <!-- Existing element picker — populates the form below with the
             selected element's current values so the user can edit in place.
             "(new element…)" is always the first option and behaves as a
             fresh add. The issuer keypair (and therefore the kid) is
             preserved across edits, so reader trust set never has to
             change when an element is tweaked. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pick an existing element to edit it (preserves issuer keypair / kid), or pick &quot;(new element…)&quot; to add another."
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerExistingElements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The DataElementIdentifier the reader will request (e.g. &quot;access&quot;, &quot;administrator&quot;, &quot;floor1&quot;)"
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editElementIdentifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="access"
            android:inputType="textNoSuggestions"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Employee / Badge ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Employee / Badge ID"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UTF-8 string written into AccessData.id (key 1, Aliro 1.0 §7.3 / Table 7-5). Default is ELATEC001. Set per-document so each entry has visibly distinct content when read back by the verifier."
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editEmployeeId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ELATEC001"
            android:inputType="textNoSuggestions"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Schedule Preset -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Schedule Preset"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selects the AccessRules and Schedules generated for this element. All presets are spec-conformant per Aliro 1.0 §7.3 — they differ only in capabilities, day mask, and time-of-day window."
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerSchedulePreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Row: Generate Test Doc + Load Sample Doc -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnGenerateTestDoc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Generate Test Doc"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnLoadSampleDoc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Load Sample Doc"
                android:backgroundTint="#1E7A4D"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Add or update element. The button label switches between
             "Add Element to Document" (when "(new element…)" is selected
             above) and "Update Element" (when an existing element is
             selected). Either path reuses the document's issuer keypair,
             so the kid stays stable per Aliro 1.0 §7.3 — readers configured
             with the same Step-Up Issuer Public Key continue to work
             without re-importing. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add a new element, or apply edits to the element selected above. Either way the document's issuer keypair is reused so the kid stays stable — readers configured with the same Step-Up Issuer Public Key continue to work without re-importing."
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnAddElement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Element to Document"
            android:backgroundTint="@color/colorPrimaryDark"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Import document -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import Document"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import a pre-built Access Document from a Credential Issuer. Provide the Base64-encoded CBOR blob and the issuer's public key for reader-side verification."
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnImportDoc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import Document\u2026"
            android:backgroundTint="@color/colorPrimaryDark"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp" />

        <!-- Mailbox divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Mailbox Contents -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mailbox Contents"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Persistent byte array accessible by authenticated readers via EXCHANGE mailbox operations. &quot;Load Sample Mailbox&quot; writes a 256-byte Aliro §18 TLV buffer with two ELATEC vendor entries (OUI 00:13:7D): Reader Configuration (Type 0x01) and Door Status (Type 0x02)."
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtMailboxSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Size: 0 bytes"
            android:textSize="13sp"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtMailboxHexDump"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(empty)"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="@color/colorTextPrimary"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:scrollbars="vertical"
            android:maxLines="20"
            android:layout_marginBottom="12dp" />

        <!-- Mailbox size selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initialize Mailbox with Zeros"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerMailboxSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Row: Initialize (zeros) + Load Sample Mailbox -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnInitMailbox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Initialize (Zeros)"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnLoadSampleMailbox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Load Sample Mailbox"
                android:backgroundTint="#1E7A4D"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Clear mailbox -->
        <Button
            android:id="@+id/btnClearMailbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear Mailbox"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp" />

        <!-- Status message (shared across all sections) -->
        <TextView
            android:id="@+id/txtCredAliroStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
