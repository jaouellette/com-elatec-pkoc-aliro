<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#101418">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1B2129"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Diagnostic Log"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtLogCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 entries"
            android:textColor="#9AA4AE"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <CheckBox
            android:id="@+id/chkAutoRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:checked="true"
            android:buttonTint="#4472C4" />

    </LinearLayout>

    <!-- Filter row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#161B21"
        android:padding="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Level:"
            android:textColor="#9AA4AE"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/spinnerLevel"
            android:layout_width="120dp"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter:"
            android:textColor="#9AA4AE"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/editFilter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="substring (e.g. AUTH1)"
            android:textColorHint="#5A6470"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:padding="6dp"
            android:background="#1B2129" />

    </LinearLayout>

    <!-- Log content area -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">

        <TextView
            android:id="@+id/txtLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D6DEE6"
            android:textSize="11sp"
            android:typeface="monospace"
            android:textIsSelectable="true"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />

    </ScrollView>

    <!-- Action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1B2129"
        android:padding="8dp">

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Refresh"
            android:textSize="11sp"
            android:backgroundTint="#4472C4"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnCopy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Copy"
            android:textSize="11sp"
            android:backgroundTint="#1E7A4D"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share"
            android:textSize="11sp"
            android:backgroundTint="#1E7A4D"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clear"
            android:textSize="11sp"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</LinearLayout>
